{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@anthropic/mcp-server-playwright"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "mobbin": {
      "type": "http",
      "url": "https://api.mobbin.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "linear-server": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "tavily-remote-mcp": {
      "type": "http",
      "url": "https://mcp.tavily.com/mcp/"
    },
    "apple-docs": {
      "command": "npx",
      "args": ["-y", "@kimsungwhee/apple-docs-mcp@latest"]
    },
    "consult": {
      "type": "stdio",
      "command": "${HOME}/code/mcp-servers/consult-mcp/.venv/bin/consult-mcp",
      "args": [],
      "env": {
        "CONSULT_ANTHROPIC_API_KEY": "${CONSULT_ANTHROPIC_API_KEY}",
        "CONSULT_MAX_INPUT_USD": "1.50",
        "CONSULT_SPEND_LOG": "${HOME}/.consult-mcp/spend.jsonl"
      }
    },
    "projects": {
      "type": "stdio",
      "command": "node",
      "args": ["${HOME}/code/mcp-servers/projects-mcp/dist/index.js"],
      "env": {}
    },
    "telegram": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "${HOME}/code/mcp-servers/telegram-mcp", "run", "tg-mcp-server"],
      "env": {
        "TG_MCP_READONLY": "0",
        "TG_MCP_ALLOWLIST": "${TG_MCP_ALLOWLIST}"
      }
    }
  }
}
