# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored — never commit it.

# MCP server secrets (see ../claude/mcp.json — shared across machines).
# Exported into the shell where `claude` runs; Claude Code expands the ${VAR}
# refs in mcp.json. See ../claude/README.md for the full server/prereq table.

# Anthropic API key for the local consult-mcp server (consult).
CONSULT_ANTHROPIC_API_KEY=<anthropic-api-key>   # sk-ant-... from console.anthropic.com

# Telegram MCP (telegram) — ABSOLUTE PATH to a JSON allowlist file (NOT the ids
# themselves). The file is a list or {"chats":[...]} of numeric chat ids /
# @usernames the server may send to (Saved Messages = your own account id).
# Telegram login is stored in the OS keyring (run `uv run tg-mcp-auth`).
TG_MCP_ALLOWLIST=<absolute-path-to-allowlist.json>

# NOTE: `projects` reads its own git-ignored .env (copy mcp-servers/projects-mcp/
# .env.example → .env with PROJECTS_API_BASE/LOGIN/PASSWORD) — not this file.
#
# Server code for consult/projects/telegram/p7 lives in the private mcp-servers
# repo: gh repo clone vladpolewoi/mcp-servers ~/code/mcp-servers  (then build per
# each dir's SETUP.md). See ../claude/README.md.
