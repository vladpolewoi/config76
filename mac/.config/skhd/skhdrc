# ── Focus window (ctrl + hjkl) ──
ctrl - h : yabai -m window --focus west
ctrl - j : yabai -m window --focus south
ctrl - k : yabai -m window --focus north
ctrl - l : yabai -m window --focus east

# ── Swap window (alt+shift + hjkl) ──
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

# ── Move window (ctrl+alt + hjkl) ──
ctrl + alt - h : yabai -m window --warp west
ctrl + alt - j : yabai -m window --warp south
ctrl + alt - k : yabai -m window --warp north
ctrl + alt - l : yabai -m window --warp east

# ── Resize window ──
shift + alt - 0x18 : yabai -m space --balance          # alt+shift+=  balance all
ctrl + alt - left  : yabai -m window --resize left:-50:0
ctrl + alt - right : yabai -m window --resize right:50:0
ctrl + alt - up    : yabai -m window --resize top:0:-50
ctrl + alt - down  : yabai -m window --resize bottom:0:50

# ── Maximize / fullscreen ──
ctrl - f         : yabai -m window --toggle zoom-fullscreen
shift + ctrl - f : yabai -m window --toggle native-fullscreen

# ── Toggle float + center ──
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# ── Toggle split direction ──
alt - e : yabai -m window --toggle split

# ── Spaces (alt + 1-6) ──
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6

# ── Move window to space (shift+alt + 1-6) ──
shift + alt - 1 : yabai -m window --space 1
shift + alt - 2 : yabai -m window --space 2
shift + alt - 3 : yabai -m window --space 3
shift + alt - 4 : yabai -m window --space 4
shift + alt - 5 : yabai -m window --space 5
shift + alt - 6 : yabai -m window --space 6

# ── Move window to space (cmd+shift + 7/8/9/0) ──
cmd + shift - 7 : yabai -m window --space 1
cmd + shift - 8 : yabai -m window --space 2
cmd + shift - 9 : yabai -m window --space 3
cmd + shift - 0 : yabai -m window --space 4

# ── Rotate tree ──
alt - r : yabai -m space --rotate 270

# ── Close window ──
shift + alt - q : yabai -m window --close
