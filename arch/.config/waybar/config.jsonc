{
  "layer": "top",
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock#time"],
  "modules-right": [
    "custom/music",
    "custom/weather",
    "clock#date",
    "network",
    "custom/tmux",
    "custom/claude",
    "cpu",
    "memory",
    "pulseaudio",
  ],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "format-icons": {
      "1": "п„ ",
      "2": "п‰Ё",
      "3": "п„Ў",
      "4": "п†ј",
      "5": "пЃµ",
      //"urgent": "пЃЄ",
      //"active": "п†’",
      "default": "п„‘",
    },
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": 5,
    },
  },

  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon}вЂ‚{volume}%",
    "format-muted": "{icon}вЂ‚{volume}%",

    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": ["пЂ¦", "пЂ§", "пЂЁ"],
    },
  },

  "network": {
    "tooltip": false,
    "format-wifi": "п‡«вЂ‚вЂ‚{essid}",
    "format-ethernet": "",
  },

  "clock#time": {
    "format": "<span>пЂ—</span>вЂ‚{:%H:%M}",
    "tooltip": false,
    "interval": 60,
  },

  "custom/weather": {
    "interval": 900,
    "format": "{}",
    "exec": "~/.config/waybar/scripts/get-weather.sh",
    "return-type": "plain",
    "tooltip": false,
  },

  "clock#date": {
    "format": "<span>п‘•</span>вЂ‚{:%d %a, %B}",
    "interval": 60,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "months": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
      },
    },
  },

  "custom/tmux": {
    "exec": "~/.config/waybar/scripts/tmux-sessions.sh",
    "return-type": "json",
    "interval": 3600,
    "signal": 8,
    "on-click": "~/.config/waybar/scripts/tmux-kill.sh",
    "tooltip": true,
  },

  "custom/claude": {
    "exec": "~/.config/waybar/scripts/claude-usage.sh",
    "return-type": "json",
    "interval": 600,
    "signal": 9,
    "on-click": "~/.config/waybar/scripts/claude-usage-refresh.sh",
    "tooltip": true,
  },

  "cpu": {
    "interval": 15,
    "format": "п‹›вЂ‚{}%",
    "max-length": 10,
  },

  "memory": {
    "interval": 30,
    "format": "ої…вЂ‚{}%",
    "max-length": 10,
  },
}
