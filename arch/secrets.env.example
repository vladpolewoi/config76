# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored — never commit it.

# DocSpace / DSD server IPs
DSD_CALENDAR_HOST=<calendar-server-ip>   # e.g. 185.91.xx.xx
DSD_DEV_HOST=<dev-server-ip>             # e.g. 89.208.xx.xx

# MCP server secrets (see ../claude/mcp.json — shared across machines).
# Exported into the shell where `claude` runs; Claude Code expands the ${VAR}
# refs in mcp.json. See ../claude/README.md for the full server/prereq table.

# Anthropic API key for the local consult-mcp server (consult).
CONSULT_ANTHROPIC_API_KEY=<anthropic-api-key>   # sk-ant-... from console.anthropic.com

# Telegram MCP allowlist (telegram) — comma-separated chats/users the server may
# access. Requires a checkout at ~/code/telegram-mcp (run via uv).
TG_MCP_ALLOWLIST=<comma-separated-chat-ids-or-usernames>
